# Database (required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reporium
DATABASE_PROVIDER=local  # local | supabase | gcp

# Redis (optional — API works without it, just no caching)
REDIS_URL=redis://localhost:6379

# Auth (required)
INGESTION_API_KEY=change-this-to-a-secure-random-string

# GitHub (optional — for any direct API calls)
GH_TOKEN=
GH_USERNAME=perditioinc

# Environment
ENVIRONMENT=development
