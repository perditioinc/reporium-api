# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reporium

# Admin and ingest auth headers
ADMIN_API_KEY=change-me-admin-key
INGEST_API_KEY=change-me-ingest-key

# Cache and environment
REDIS_URL=redis://localhost:6379
ENVIRONMENT=development

# GCP / Pub/Sub integration
GCP_PROJECT_ID=perditio-platform
GCP_PROJECT=perditio-platform
PUBSUB_AUDIENCE=

# Optional runtime metadata
APP_VERSION=
BUILD_NUMBER=
GITHUB_SHA=

# Optional model/webhook integrations
ANTHROPIC_API_KEY=
GITHUB_WEBHOOK_SECRET=

# Optional: when set to 1, requires X-Admin-Key header on /metrics/* and /audit/status.
# Leave unset for open metrics (default — matches pre-#236 behavior).
METRICS_REQUIRE_AUTH=
